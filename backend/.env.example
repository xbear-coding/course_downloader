# Course_Downloader 环境配置
# 复制此文件为 .env 并填写真实值

# 数据库路径（默认 SQLite，无需修改即可运行）
DATABASE_URL=sqlite+aiosqlite:///data/course_downloader.db

# FastAPI 配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Vue 前端地址（CORS）
FRONTEND_URL=http://localhost:5173

# API Key 加密密钥（首次启动自动生成并写入 .env）
# 如手动更换，需重新添加所有 API Key
# COURSE_DOWNLOADER_KEY=
